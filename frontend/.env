# TetherStream Environment Configuration
# Copy to .env.local for local development

NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org:443

# Contract addresses (fill in after deployment)
NEXT_PUBLIC_TOKEN_CONTRACT_ADDRESS=
NEXT_PUBLIC_STREAM_CONTRACT_ADDRESS=

# Testnet faucet admin secret (for minting TTH; replace with your deployed admin)
NEXT_PUBLIC_DEPLOYER_SECRET=
